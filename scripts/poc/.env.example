# Tencent Cloud API Credentials
# Copy this file to .env and fill in your actual credentials

# ============================================
# REQUIRED: Tencent Cloud API Credentials
# ============================================
# Get these from: https://console.cloud.tencent.com/cam/capi
TENCENT_SECRET_ID=your-secret-id-here
TENCENT_SECRET_KEY=your-secret-key-here

# ============================================
# OPTIONAL: Configuration
# ============================================
# Tencent Cloud region (default: ap-guangzhou)
# Available regions: ap-guangzhou, ap-beijing, ap-shanghai, etc.
TENCENT_REGION=ap-guangzhou

# Directory containing test images (default: ./test-images)
TEST_IMAGES_DIR=./test-images

# Business type for moderation API (default: default)
# Configure in Tencent Cloud console for custom rules
MODERATION_BIZ_TYPE=default

# ============================================
# SECURITY WARNING
# ============================================
# NEVER commit the .env file to version control!
# This file (.env.example) is safe to commit as it contains no real values.
# The actual .env file should be in .gitignore.
